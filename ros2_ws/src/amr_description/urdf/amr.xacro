<?xml version='1.0' encoding='utf-8'?>
<robot name="amr" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include materials -->
  <xacro:include filename="$(find amr_description)/urdf/materials.xacro"/>

  <!-- Include gazebo -->
  <xacro:include filename="$(find amr_description)/urdf/gazebo.xacro"/>

<!--Base Link-->
    <link name="base_link">
        <inertial>
            <origin xyz="-0.0005375575226599613 -6.707584396171594e-18 0.027123229308035738" rpy="0.0 0.0 0.0" />
            <mass value="1.3304963805212109" />
            <inertia ixx="0.0006492386077846532" iyy="0.0010792552099575716" izz="0.0015845361638000663" ixy="-7.091559535264415e-19" iyz="-2.420590022530638e-19" ixz="5.575992010655939e-06" />
        </inertial>
        <visual name="base_link_visual">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/base_link.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="base_link"/>
        </visual>
        <collision name="base_link_collision">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/base_link.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </collision>
    </link>

<!--Wheels-->
    <link name="f_wheel_r">
        <inertial>
            <origin xyz="0.0 0.0 0.0075" rpy="0.0 -0.0 0.0" />
            <mass value="0.027390760948486005" />
            <inertia ixx="4.793383165985085e-06" iyy="4.793383165984855e-06" izz="8.559612796401754e-06" ixy="0.0" iyz="0.0" ixz="-6.776263578034403e-21" />
        </inertial>
        <visual name="f_wheel_r_visual">
            <origin xyz="-0.04 -0.025 -0.0425" rpy="-1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/f_wheel_r.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="Wheels"/>
        </visual>
        <collision name="f_wheel_r_collision">
            <origin xyz="-0.04 -0.025 -0.0425" rpy="-1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/f_wheel_r.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </collision>
    </link>
    <link name="f_wheel_l">
        <inertial>
            <origin xyz="0.0 0.0 0.0075" rpy="0.0 -0.0 0.0" />
            <mass value="0.027390760948486005" />
            <inertia ixx="4.793383165985099e-06" iyy="4.7933831659848684e-06" izz="8.559612796401754e-06" ixy="0.0" iyz="-6.776263578034403e-21" ixz="-6.776263578034403e-21" />
        </inertial>
        <visual name="f_wheel_l_visual">
            <origin xyz="-0.04 0.025 -0.0425" rpy="1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/f_wheel_l.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="Wheels"/>
        </visual>
        <collision name="f_wheel_l_collision">
            <origin xyz="-0.04 0.025 -0.0425" rpy="1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/f_wheel_l.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </collision>
    </link>
    <link name="b_wheel_r">
        <inertial>
            <origin xyz="-8.881784197001253e-18 0.0 0.0075" rpy="0.0 -0.0 0.0" />
            <mass value="0.027390760948486005" />
            <inertia ixx="4.793383165985085e-06" iyy="4.793383165984841e-06" izz="8.559612796401754e-06" ixy="-6.776263578034403e-21" iyz="0.0" ixz="-6.776263578034403e-21" />
        </inertial>
        <visual name="b_wheel_r_visual">
            <origin xyz="0.04 -0.025 -0.0425" rpy="-1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/b_wheel_r.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="Wheels"/>
        </visual>
        <collision name="b_wheel_r_collision">
            <origin xyz="0.04 -0.025 -0.0425" rpy="-1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/b_wheel_r.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </collision>
    </link>
    <link name="b_wheel_l">
        <inertial>
            <origin xyz="-8.881784197001253e-18 0.0 0.0075" rpy="0.0 -0.0 0.0" />
            <mass value="0.027390760948486005" />
            <inertia ixx="4.793383165985099e-06" iyy="4.793383165984841e-06" izz="8.559612796401754e-06" ixy="6.776263578034403e-21" iyz="-6.776263578034403e-21" ixz="-1.3552527156068805e-20" />
        </inertial>
        <visual name="b_wheel_l_visual">
            <origin xyz="0.04 0.025 -0.0425" rpy="1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/b_wheel_l.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="Wheels"/>
        </visual>
        <collision name="b_wheel_l_collision">
            <origin xyz="0.04 0.025 -0.0425" rpy="1.5707963267948966 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/b_wheel_l.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </collision>
    </link>

<!--Camera link-->
    <link name="camera_link">
        <inertial>
            <origin xyz="2.1144401675929903e-05 -2.0784716164913716e-18 0.004999999999999991" rpy="0.0 -0.0 0.0" />
            <mass value="0.02186537558266994" />
            <inertia ixx="1.6402649642970762e-06" iyy="3.5588437804215866e-07" izz="1.6574154808891354e-06" ixy="2.423405746323952e-19" iyz="-2.0916601783937933e-21" ixz="0.0" />
        </inertial>
        <visual name="camera_link_visual">
            <origin xyz="-0.01916700333333333 1.1102230246251566e-18 -0.055" rpy="0.0 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/camera_link.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </visual>
        <collision name="camera_link_collision">
            <origin xyz="-0.01916700333333333 1.1102230246251566e-18 -0.055" rpy="0.0 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/camera_link.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="camera_link"/>
        </collision>
    </link>

<!--Lidar link-->
    <link name="lidar_link">
        <inertial>
            <origin xyz="2.261727773485168e-18 -2.261727773485168e-18 0.003999999999999999" rpy="0.0 -0.0 0.0" />
            <mass value="0.030826877913349836" />
            <inertia ixx="1.3685849340280403e-06" iyy="1.3685849340281089e-06" izz="2.4083498369804176e-06" ixy="-2.091660178393795e-21" iyz="4.531930386519889e-22" ixz="-4.531930386519889e-22" />
        </inertial>
        <visual name="lidar_link_visual">
            <origin xyz="0.0 0.0 0.013000000000000001" rpy="3.141592653589793 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/lidar_link.stl" scale="0.01 0.01 0.01" />
            </geometry>
            <material name="lidar_link"/>
        </visual>
        <collision name="lidar_link_collision">
            <origin xyz="0.0 0.0 0.013000000000000001" rpy="3.141592653589793 -0.0 0.0" />
            <geometry>
                <mesh filename="package://amr_description/meshes/lidar_link.stl" scale="0.01 0.01 0.01" />
            </geometry>
        </collision>
    </link>
    <joint name="base_link_f_wheel_r_revolute" type="continuous">
        <origin xyz="0.04 -0.0425 0.025" rpy="1.5707963267948966 -0.0 0.0" />
        <parent link="base_link" />
        <child link="f_wheel_r" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="base_link_f_wheel_l_revolute" type="continuous">
        <origin xyz="0.04 0.0425 0.025" rpy="-1.5707963267948966 -0.0 0.0" />
        <parent link="base_link" />
        <child link="f_wheel_l" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="base_link_b_wheel_l_revolute" type="continuous">
        <origin xyz="-0.04 0.0425 0.025" rpy="-1.5707963267948966 -0.0 0.0" />
        <parent link="base_link" />
        <child link="b_wheel_l" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="base_link_b_wheel_r_revolute" type="continuous">
        <origin xyz="-0.04 -0.0425 0.025" rpy="1.5707963267948966 -0.0 0.0" />
        <parent link="base_link" />
        <child link="b_wheel_r" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="base_link_camera_rotation" type="continuous">
        <origin xyz="0.01916667 0.0 0.055" rpy="0.0 -0.0 0.0" />
        <parent link="base_link" />
        <child link="camera_link" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>
    <joint name="base_link_lidar_rotation" type="continuous">
        <origin xyz="0.0 0.0 0.013000000000000001" rpy="3.141592653589793 -0.0 0.0" />
        <parent link="base_link" />
        <child link="lidar_link" />
        <axis xyz="0.0 0.0 1.0" />
    </joint>
</robot>
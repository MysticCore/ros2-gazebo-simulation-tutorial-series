<?xml version="1.0" ?>
<robot name="amr" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find amr_description)/urdf/materials.xacro" />
<xacro:include filename="$(find amr_description)/urdf/amr.trans" />
<xacro:include filename="$(find amr_description)/urdf/amr.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="0.0 8.902012997990435e-05 0.0005969174994691003" rpy="0 0 0"/>
    <mass value="1.202294246159139"/>
    <inertia ixx="0.001027" iyy="0.000603" izz="0.001535" ixy="0.0" iyz="-1e-06" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://amr_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://amr_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="f_wheel_link_1">
  <inertial>
    <origin xyz="-3.313617118894079e-17 -3.319497454690179e-13 3.469446951953614e-20" rpy="0 0 0"/>
    <mass value="0.20199414508982372"/>
    <inertia ixx="3.7e-05" iyy="0.000378" izz="0.000378" ixy="-0.0" iyz="-0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 0.0375 -0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://amr_description/meshes/f_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.0 0.0375 -0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://amr_description/meshes/f_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="b_wheel_link_1">
  <inertial>
    <origin xyz="2.2090780792627208e-17 3.319566843629218e-13 0.0" rpy="0 0 0"/>
    <mass value="0.20199414508982363"/>
    <inertia ixx="3.7e-05" iyy="0.000378" izz="0.000378" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 -0.0375 -0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://amr_description/meshes/b_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.0 -0.0375 -0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://amr_description/meshes/b_wheel_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="f_wheel_joint" type="continuous">
  <origin xyz="0.0 -0.0375 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="f_wheel_link_1"/>
  <axis xyz="1.0 0.0 0.0"/>
</joint>

<joint name="b_wheel_joint" type="continuous">
  <origin xyz="0.0 0.0375 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="b_wheel_link_1"/>
  <axis xyz="1.0 0.0 0.0"/>
</joint>

</robot>

            <mass value="0.10481138490538972" />
            <inertia ixx="1.4602382288275532e-05" iyy="1.4602382285722263e-05" izz="1.9748468661930866e-05" ixy="0.0" iyz="3.412526337898125e-17" ixz="1.1155520951433573e-20" />
